rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function isOwn(userId) {
      return isAuth() && uid() == userId;
    }
    function isAdmin() {
      return isAuth()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'ysezenn@outlook.com';
    }
    function isRoomMember(roomId) {
      let room = get(/databases/$(database)/documents/rooms/$(roomId)).data;
      return isAuth() && (
        uid() in room.memberUids ||
        uid() == room.hostUid
      );
    }

    // ---- Kullanıcılar ----
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwn(userId);
      allow update: if isOwn(userId) ||
        (isAuth() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friendIds']));
      allow delete: if isOwn(userId);

      match /history/{entryId} {
        allow read, write: if isOwn(userId);
      }
    }

    // ---- Odalar ----
    match /rooms/{roomId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && uid() == resource.data.hostUid;

      match /messages/{msgId} {
        allow read: if isRoomMember(roomId) || isAdmin();
        allow create: if isRoomMember(roomId)
          && (request.resource.data.senderUid == uid()
              || request.resource.data.system == true);
        allow update, delete: if isRoomMember(roomId)
          && (resource.data.senderUid == uid() || isAdmin());
      }

      // Ekran paylaşımı WebRTC sinyali (offer/answer/ICE)
      match /webrtc/{doc=**} {
        allow read, write: if isRoomMember(roomId) || isAdmin();
      }

      // Sesli sohbet — katılımcı varlık listesi
      match /voicePeers/{peerUid} {
        allow read: if isRoomMember(roomId) || isAdmin();
        allow write: if isRoomMember(roomId) && uid() == peerUid;
      }

      // Sesli sohbet — WebRTC offer/answer/ICE sinyalizasyonu
      match /voiceConn/{connId} {
        allow read, write: if isRoomMember(roomId) || isAdmin();

        match /offerCandidates/{candidateId} {
          allow read, write: if isRoomMember(roomId) || isAdmin();
        }
        match /answerCandidates/{candidateId} {
          allow read, write: if isRoomMember(roomId) || isAdmin();
        }
      }
    }

    // ---- İstekler ----
    // Arkadaşlık docId: {toUid}_{fromUid}_friend  |  Oda daveti: {toUid}_{roomId}
    match /requests/{reqId} {
      // Create/update: gönderen kendi fromUid'ini yazar
      allow create, update: if isAuth()
        && request.resource.data.fromUid == uid();

      // Delete: gönderen veya alıcı silebilir
      allow delete: if isAuth();

      // Read: gönderen veya alıcı okuyabilir
      allow read: if isAuth()
        && (resource.data.toUid == uid() || resource.data.fromUid == uid());
    }

    // ---- Şikayetler ----
    match /reports/{reportId} {
      allow create: if isAuth();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ---- Doğrudan Mesajlar (DM) ----
    match /dms/{dmId} {
      // READ: participantUids sorgusu ile uyumlu (array-contains); admin tümünü okur.
      allow read: if isAuth() && (uid() in resource.data.participantUids || isAdmin());

      allow create: if isAuth() && uid() in request.resource.data.participantUids;

      allow update: if isAuth() && uid() in resource.data.participantUids;

      // Katılımcılar arkadaş silince konuşmayı tamamen kaldırabilir
      allow delete: if isAuth() && uid() in resource.data.participantUids;

      match /messages/{msgId} {
        allow read: if isAuth() && (
          uid() in get(/databases/$(database)/documents/dms/$(dmId)).data.participantUids
          || isAdmin()
        );
        allow write: if isAuth()
          && uid() in get(/databases/$(database)/documents/dms/$(dmId)).data.participantUids;
      }
    }
  }
}
