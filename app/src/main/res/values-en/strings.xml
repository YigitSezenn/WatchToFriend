    <string name="help_title">Help &amp; FAQ</string>
    <string name="help_close">Close</string>
    <string name="help_q1">How do I create a room?</string>
    <string name="help_a1">Tap + on the home screen, add a video link, and share the invite code or link with friends.</string>
    <string name="help_q2">How does video sync work?</string>
    <string name="help_a2">When the host or moderators play or pause, everyone in the room updates at the same time.</string>
    <string name="help_q3">How do I use voice chat?</string>
    <string name="help_a3">Tap the microphone icon in the watch room. Headphones reduce echo.</string>
    <string name="help_q4">Screen sharing</string>
    <string name="help_a4">Tap screen share in the room and grant permission. Viewers see your screen live.</string>
    <string name="help_q5">How do I change the language?</string>
    <string name="help_a5">Profile → Language: choose Turkish, English, or System default.</string>
    <string name="help_q6">Support</string>
    <string name="help_a6">Update the app and check your connection. You can leave feedback via the store rating.</string>

