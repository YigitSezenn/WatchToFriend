    <string name="tour_1_title">Welcome to WatchToFriend</string>
    <string name="tour_1_body">Watch videos with friends in sync, chat, and talk on the voice channel.</string>
    <string name="tour_2_title">Bottom menu</string>
    <string name="tour_2_body">My rooms, Discover, Friends, and direct messages are here.</string>
