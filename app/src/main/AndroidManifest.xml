<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- ExoPlayer akış sırasında CPU/Wi-Fi'yi uyanık tutsun (takılmaları önler) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Android 13+ push bildirimleri için izin -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Ekran paylaşımı için ön plan servis izinleri -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- Ekran sesi (WebRTC ekran paylaşımı için opsiyonel) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Xiaomi/MIUI: programatik ses seviyesi ve hoparlör yönlendirmesi -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <application
        android:name=".WatchApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WatchToFriend"
        android:usesCleartextTraffic="true">
        <!-- Firestore ayarları (long polling) — FirebaseInitProvider'dan hemen sonra -->
        <provider
            android:name=".data.FirebaseBootstrapProvider"
            android:authorities="${applicationId}.firebasebootstrap"
            android:exported="false"
            android:initOrder="101" />

        <!-- Ekran paylaşımı ön plan servisi (MediaProjection Android 10+ zorunluluğu) -->
        <service
            android:name=".ui.watch.ScreenShareService"
            android:foregroundServiceType="mediaProjection"
            android:exported="false" />

        <service
            android:name=".ui.watch.VoiceChatService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

        <service
            android:name=".FcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:supportsPictureInPicture="true"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.WatchToFriend"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Davet linki: https://watchtofriend.web.app/join/ABC123 -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="watchtofriend.web.app"
                    android:pathPrefix="/join" />
            </intent-filter>
            <!-- Özel alan adı (DNS aktif olduğunda) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="watchtofriend.app"
                    android:pathPrefix="/join" />
            </intent-filter>
            <!-- Uygulama şeması: watchtofriend://join/ABC123 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="watchtofriend"
                    android:host="join"
                    android:pathPrefix="/" />
            </intent-filter>
        </activity>
    </application>

</manifest>
